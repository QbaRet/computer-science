DELIMITER $$

CREATE PROCEDURE AddEmployees()
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE t_pesel CHAR(11);
    DECLARE t_birthdate DATE;
    DECLARE t_gender ENUM('K', 'M');
    DECLARE t_age INT;
    
    DECLARE random_profession_id INT;
    DECLARE rnd_salary FLOAT;

    DECLARE ludzie_cursor CURSOR FOR
        SELECT PESEL, data_urodzenia, plec
        FROM Ludzie
        WHERE TIMESTAMPDIFF(YEAR, data_urodzenia, CURDATE()) >= 18;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;

    OPEN ludzie_cursor;

    ludzie_loop: LOOP
        FETCH ludzie_cursor INTO t_pesel, t_birthdate, t_gender;

        IF done THEN
            LEAVE ludzie_loop;
        END IF;
        SET t_age = TIMESTAMPDIFF(YEAR, t_birthdate, CURDATE());
        SELECT zawod_id, (pensja_min + RAND() * (pensja_max - pensja_min))
        INTO random_profession_id, rnd_salary
        FROM Zawody
        WHERE 
            nazwa != 'Lekarz' 
            OR (nazwa = 'Lekarz' AND t_gender = 'K' AND t_age <= 60)
            OR (nazwa = 'Lekarz' AND t_gender = 'M' AND t_age <= 65)
        ORDER BY RAND()
        LIMIT 1;
        IF NOT EXISTS (SELECT 1 FROM Pracownicy WHERE PESEL = t_pesel) THEN
            INSERT INTO Pracownicy (PESEL, zawod_id, pensja, osoba_id)
            VALUES (
                t_pesel, 
                random_profession_id, 
                rnd_salary, 
                (SELECT ID FROM Ludzie WHERE PESEL = t_pesel)
            );
        END IF;

    END LOOP;

    CLOSE ludzie_cursor;
END $$
DELIMITER ;
CALL AddEmployees();

