DELIMITER //
CREATE FUNCTION czy_pesel_poprawny(pesel CHAR(11)) 
RETURNS BOOLEAN
DETERMINISTIC
BEGIN
    DECLARE suma INT;
    DECLARE kontrolna INT;
    
    IF pesel NOT REGEXP '^[0-9]{11}$' THEN RETURN 0; END IF;

    SET suma = 
        SUBSTR(pesel, 1, 1) * 1 + SUBSTR(pesel, 2, 1) * 3 +
        SUBSTR(pesel, 3, 1) * 7 + SUBSTR(pesel, 4, 1) * 9 +
        SUBSTR(pesel, 5, 1) * 1 + SUBSTR(pesel, 6, 1) * 3 +
        SUBSTR(pesel, 7, 1) * 7 + SUBSTR(pesel, 8, 1) * 9 +
        SUBSTR(pesel, 9, 1) * 1 + SUBSTR(pesel, 10, 1) * 3;

    SET kontrolna = (10 - (suma % 10)) % 10;
    
    RETURN kontrolna = SUBSTR(pesel, 11, 1);
END //
DELIMITER ;


CREATE TABLE Ludzie(
ID INT AUTO_INCREMENT PRIMARY KEY,
PESEL CHAR(11) NOT NULL UNIQUE,
imie VARCHAR(30) NOT NULL,
nazwisko VARCHAR(30) NOT NULL,
data_urodzenia DATE,
plec ENUM('K','M'));

CREATE TABLE Zawody(
zawod_id INT AUTO_INCREMENT PRIMARY KEY,
nazwa VARCHAR(50) NOT NULL,
pensja_min FLOAT CHECK (pensja_min>0),
pensja_max FLOAT CHECK (pensja_max>0),
CHECK (pensja_min<pensja_max));

CREATE TABLE Pracownicy(
osoba_id INT,
zawod_id INT,
PESEL CHAR(11),
pensja FLOAT CHECK (pensja > 0),
FOREIGN KEY (osoba_id) REFERENCES Ludzie(ID),
FOREIGN KEY (zawod_id) REFERENCES Zawody(zawod_id)
);

DELIMITER //
CREATE TRIGGER sprawdz_pesel_tylko_walidacja
BEFORE INSERT ON Ludzie
FOR EACH ROW
BEGIN
    IF czy_pesel_poprawny(NEW.PESEL) = 0 THEN
        SIGNAL SQLSTATE '45000' 
        SET MESSAGE_TEXT = 'Błąd: Nieprawidłowy numer PESEL (zła suma kontrolna).';
    END IF;
END //
DELIMITER ;


