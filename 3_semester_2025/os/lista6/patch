+void 
+vmprint(pde_t *pgdir)
+{
+  cprintf("pgdir pa %p\n",V2P(pgdir));
+  for(int i=0;i<512;i++)
+  {
+    pde_t pde =pgdir[i];
+    if(pde & PTE_P)
+    {
+      cprintf(".. %d: pde pa %p flags %p\n",i, PTE_ADDR(pde), (uint)PTE_FLAGS(pde));
+      pte_t *pt = (pte_t*)P2V(PTE_ADDR(pde));
+      for(int j=0;j<1024;j++)
+        {
+          pte_t pte =pt[j];
+          if(pte & PTE_P)
+              {
+            uint va = (i * 1024 * 4096) + (j * 4096);
+            cprintf(".. .. %d: pte pa %p va %p flags %p\n", j, PTE_ADDR(pte), va, (uint)PTE_FLAGS(pte));
+          }
+        }
+    }
+    
+  }
+}
+
+int
+count_virtual_pages(uint sz)
+{
+  return (sz+PGSIZE-1)/PGSIZE;
+}
+
+int
+count_physical_pages(pde_t *pgdir, uint sz)
+{
+  int count =0;
+  pde_t *pte;
+  for(uint i=0; i<sz; i+=PGSIZE)
+  {
+    pte = walkpgdir(pgdir, (void*)i,0);
+    if(pte!=0 && (*pte & PTE_P)){ 
+      count ++;
+    }
+  }
+  return count;
+}
+
+int 
+shmget_logic(pde_t *pgdir)
+{
+  acquire(&shm.lock);
+  if(shm.pa==0){
+    if((shm.pa=kalloc())==0){
+      release(&shm.lock);
+      return -1;
+    }
+    memset(shm.pa,0,PGSIZE);
+  }
+  pte_t *pte=walkpgdir(pgdir,(void*)SHM_VA,0);
+  if(pte == 0 || !(*pte & PTE_P)) {
+    if(mappages(pgdir, (void*)SHM_VA, PGSIZE, V2P(shm.pa), PTE_W|PTE_U) < 0) {
+      release(&shm.lock);
+      return -1;
+    }
+    shm.refcount++;
+  }
+  release(&shm.lock);
+  return 0;
+}
+
+void shm_release(pde_t *pgdir) {
+  acquire(&shm.lock);
+  if(shm.pa != 0) {
+    pte_t *pte = walkpgdir(pgdir, (void*)SHM_VA, 0);
+    if(pte != 0 && (*pte & PTE_P)) {
+      shm.refcount--;
+      if(shm.refcount == 0) {
+        kfree(shm.pa);
+        shm.pa = 0;
+      }
+    }
+  }
+  release(&shm.lock);
+}
