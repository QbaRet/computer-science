+#include "spinlock.h"
 #include "mmu.h"
 #include "proc.h"
+struct semaphore {
+  struct spinlock lock;
+  int count;
+  int active;
+};
+struct semaphore semtab[10];
+int
+sys_sem_init(void)
+{
+  int i,v;
+  if(argint(0, &i) < 0 || argint(1, &v) < 0 || i < 0 || i >= 10){
+    return -1;}
+  initlock(&semtab[i].lock, "semaphore");
+  acquire(&semtab[i].lock);
+  semtab[i].count = v;
+  semtab[i].active = 1;
+  release(&semtab[i].lock);
+  return 0;  
+}
+sys_sem_up(void)
+{
+  int i;
+  if(argint(0, &i) < 0 || i < 0 || i >= 10 || !semtab[i].active)
+    return -1;
+
+  acquire(&semtab[i].lock);
+  semtab[i].count++;
+  wakeup(&semtab[i]); 
+  release(&semtab[i].lock);
+  return 0;
+}
 
+int
+sys_sem_down(void)
+{
+  int i;
+  if(argint(0, &i) < 0 || i < 0 || i >= 10 || !semtab[i].active)
+    return -1;
+
+  acquire(&semtab[i].lock);
+  while(semtab[i].count <= 0){
+    sleep(&semtab[i], &semtab[i].lock);
+  }
+  semtab[i].count--;
+  release(&semtab[i].lock);
+  return 0;
+}
