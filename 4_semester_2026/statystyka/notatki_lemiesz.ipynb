   "source": [
    "# Verify that residuals follow normal distribution using Q-Q plots\n",
    "fig = plt.figure(figsize=(9, 9))\n",
    "\n",
    "for i, model in enumerate(models, start=1):\n",
    "    ax = fig.add_subplot(3, 3, i)\n",
    "\n",
    "    result = myLinReg(model, df)\n",
    "\n",
    "    resid_std = (result.resid - result.resid.mean()) / result.resid.std()\n",
    "\n",
    "    sm.qqplot(resid_std, line=\"45\", ax=ax)\n",
    "\n",
    "    ax.set_title(model)\n",
    "    ax.set_xlabel(\"Theoretical quantiles\")\n",
    "    ax.set_ylabel(\"Standardized residual quantiles\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
