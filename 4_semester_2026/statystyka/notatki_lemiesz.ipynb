   "source": [
    "seed =  123\n",
    "k = 10 # numer of folds\n",
    "results = []\n",
    "names = []\n",
    "\n",
    "for formula in models:\n",
    "    # y i X from patsy\n",
    "    y, X = dmatrices(formula, data=df, return_type='dataframe')\n",
    "    Y = y.values.ravel()\n",
    "    X_mat = X.values\n",
    "\n",
    "    model = LinearRegression()\n",
    "    kfold = KFold(n_splits=k, random_state=seed, shuffle=True)\n",
    "\n",
    "    # cross_val_score returns negative MSE\n",
    "    cv_results = cross_val_score(\n",
    "        model,\n",
    "        X_mat,\n",
    "        Y,\n",
    "        cv=kfold,\n",
    "        scoring='neg_mean_squared_error'\n",
    "    )\n",
    "\n",
    "    mse_results = -cv_results\n",
    "\n",
    "    results.append(mse_results)\n",
    "    names.append(formula)\n",
    "\n",
    "    print(f\"{formula}\")\n",
    "    print(f\"    mean MSE: {mse_results.mean():.4f}    std: {mse_results.std():.4f}\\n\")\n",
    "\n",
    "# boxplot \n",
    "fig = plt.figure(figsize=(12, 6))\n",
    "fig.suptitle('Linear Regression Model Comparison (RMSE)')\n",
    "ax = fig.add_subplot(111)\n",
    "plt.boxplot(results)\n",
    "ax.set_xticklabels(names, rotation=20, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
